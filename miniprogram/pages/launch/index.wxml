<navigation-bar title="mall-mini" back="{{false}}" background="#f3f5f7"></navigation-bar>

<view class="page-shell">
  <view class="page-body">
    <view class="page-hero">
      <text class="page-eyebrow">HARNESS READY</text>
      <text class="page-title">原生小程序工程骨架已完成接管</text>
      <text class="page-subtitle">
        当前环境：{{envLabel}}。这里仅保留项目启动页，真实业务页面将在对应需求卡片确认后再新增。
      </text>
    </view>

    <view class="page-card">
      <text class="section-title">当前状态</text>
      <view class="tag-row">
        <text wx:for="{{statusTags}}" wx:key="text" class="tag">{{item.text}}</text>
      </view>
    </view>
  </view>
</view>
