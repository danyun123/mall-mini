<navigation-bar title="登录" homeButton="{{true}}" background="#f3f5f7"></navigation-bar>

<view class="page-shell">
  <view class="page-body">
    <view class="page-hero">
      <text class="page-eyebrow">AUTH SHELL</text>
      <text class="page-title">登录页占位</text>
      <text class="page-subtitle">
        当前阶段只提供 mock 登录，用来打通主包路由、全局 store 和手动验证链路。
      </text>
    </view>

    <view class="page-card">
      <text class="section-title">会话状态</text>
      <view class="tag-row">
        <text class="tag">{{isAuthenticated ? '已登录' : '未登录'}}</text>
        <text class="tag">{{displayName}}</text>
        <text class="tag">{{currentRole}}</text>
      </view>
      <view class="page-actions">
        <button class="page-button" bindtap="loginAsPurchaser">模拟采购人登录</button>
        <button class="page-button page-button--secondary" bindtap="loginAsReviewer">
          模拟审查人登录
        </button>
        <button class="page-button page-button--ghost" bindtap="goLaunch">回到启动页</button>
      </view>
    </view>
  </view>
</view>
